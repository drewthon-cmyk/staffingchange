# Server
PORT=3000
NODE_ENV=production
BASE_URL=http://your-server-ip:3000

# JWT Secret (generate a long random string)
JWT_SECRET=replace-with-a-very-long-random-secret-string-here

# Email (SMTP)
SMTP_HOST=mail.gckschools.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=personnel@gckschools.com
SMTP_PASS=your-email-password
EMAIL_FROM=personnel@gckschools.com
EMAIL_FROM_NAME=Garden City Transfer Center

# Google Drive API (Service Account)
# Create a service account in Google Cloud Console and download the JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here

# HR Admin Emails (comma-separated, no spaces)
HR_ADMIN_EMAILS=personnel@gckschools.com,hr@gckschools.com
